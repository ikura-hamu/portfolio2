---
import { getEntry } from "astro:content";
import { Icon } from "astro-icon/components";

const allSkills = await getEntry("skill", "skills");

const skills = allSkills
  ? allSkills.data.map((skill) => {
      return {
        name: skill.name,
        description: skill.description,
        icon: skill.icon,
      };
    })
  : [];
---

<div class="flex flex-col gap-s3">
  {
    skills.map((skill) => (
      <div class="border-2 border-dark rounded-md flex min-w-60 max-w-full">
        <div class="grid m-s2 items-center dark:bg-white/20 rounded-md">
          <Icon name={skill.icon} size={60} />
        </div>
        <div class="m-s2 flex flex-col gap-s2">
          <div class="text-xl font-bold">{skill.name}</div>
          <p class="">{skill.description}</p>
        </div>
      </div>
    ))
  }
</div>
