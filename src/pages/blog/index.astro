---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import BlogPostCard from "@/components/BlogPostCard.astro";
import { JSDOM } from "jsdom";
import ViewMoreButton from "@/components/ViewMoreButton.astro";

const blogs = (await getCollection("blog")).sort(
  (a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0)
);

const fetchTrapBlogs = async () => {
  const res = await fetch("https://trap.jp/author/ikura-hamu/rss/");
  const text = await res.text();
  const doms = new JSDOM(text, { contentType: "text/xml" });
  const itemElements = doms.window.document.getElementsByTagName("item");

  type Blog = {
    title: string;
    url: string;
    pubDate: Date;
    heroImage: string;
  };

  const blogs: Blog[] = [];

  for (let i = 0; i < itemElements.length; i++) {
    const itemElement = itemElements[i];
    const article: Blog = {
      title: itemElement.getElementsByTagName("title")[0]?.textContent ?? "",
      url: itemElement.getElementsByTagName("link")[0]?.textContent ?? "",
      pubDate: new Date(
        itemElement.getElementsByTagName("pubDate")[0]?.textContent ?? ""
      ),
      heroImage:
        itemElement
          .getElementsByTagName("media:content")[0]
          ?.getAttribute("url") ?? "",
    };
    blogs.push(article);
  }

  return blogs;
};

const trapBlogs = await fetchTrapBlogs();
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main {
        width: 960px;
      }
      ul {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        list-style-type: none;
        margin: 0;
        padding: 0;
      }
      ul li {
        width: calc(50% - 8px);
      }
      ul li * {
        text-decoration: none;
        transition: 0.2s ease;
      }

      main {
        max-width: calc(100% - 2em);
      }

      @media (max-width: 720px) {
        ul {
          gap: 8px;
        }
        ul li {
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="flex flex-col gap-s4">
        <ul class="">
          {
            blogs.map((post) => (
              <li>
                <BlogPostCard post={post} />
              </li>
            ))
          }
        </ul>
      </section>
      <hr class="border-4 border-primary my-s6" />

      <section class="flex flex-col gap-s4">
        <h2>traPでのブログ</h2>
        外部ページに飛びます
        <ul class="">
          {
            trapBlogs.map((post) => (
              <li>
                <BlogPostCard post={post} />
              </li>
            ))
          }
        </ul>
        <ViewMoreButton
          extraContent={{
            icon: "ri:external-link-fill",
            name: "traP 公式ページ",
            url: "https://trap.jp/author/ikura-hamu",
          }}
        />
      </section>
      <Footer />
    </main>
  </body>
</html>
